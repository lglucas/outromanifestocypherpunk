---
import DossieFrame from '../layouts/DossieFrame.astro';
import Terminal from '../components/Terminal.astro';
import SubjectCard from '../components/SubjectCard.astro';
import Stamp from '../components/dossie/Stamp.astro';
export const prerender = false;
const { showTerminal } = Astro.locals;
const desc = 'Você deixou de ser cidadão. Virou usuário. O Outro Manifesto Cypherpunk — por que a tecnologia que prometia libertar virou o braço mais eficiente de controle. Livro grátis (CC BY-SA).';
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'O Outro Manifesto Cypherpunk', url: 'https://outromanifesto.space' },
  {
    '@context': 'https://schema.org', '@type': 'Book', name: 'O Outro Manifesto Cypherpunk',
    author: { '@type': 'Person', name: 'Lucas Lopes Galvão' }, inLanguage: 'pt-BR',
    about: 'privacidade, vigilância, criptografia, blockchain, inteligência artificial',
    license: 'https://creativecommons.org/licenses/by-sa/4.0/', isAccessibleForFree: true,
    url: 'https://outromanifesto.space',
  },
];
---
{showTerminal && <Terminal />}
<DossieFrame title="ARQUIVO Nº 0001 — VOCÊ" current="/" description={desc} jsonLd={jsonLd}>
  <h1 class="arquivo-no">ARQUIVO Nº 0001 — <span class="you" data-egg="nome">VOCÊ</span></h1>
  <p class="docsub">O Outro Manifesto Cypherpunk — por que a tecnologia que prometia libertar virou braço do controle.</p>

  <div class="folha-tag">Ficha do sujeito</div>
  <SubjectCard />

  <p class="tese-home">Você deixou de ser cidadão. <span style="color:var(--brasa2)">Virou usuário.</span></p>

  <p class="slogan-unico">A tecnologia que prometia libertar virou o braço mais eficiente de controle que já existiu. <span>E ainda transformou isso numa palestra de inovação.</span></p>

  <div class="stamp-row">
    <Stamp big rot={1}>DON'T TRUST, VERIFY</Stamp>
    <Stamp big tone="cold" rot={2}>CODE IS LAW</Stamp>
    <Stamp big rot={3}>PRIVACY IS NORMAL</Stamp>
    <Stamp big tone="red" rot={4}>FREEDOM OVER CONVENIENCE</Stamp>
  </div>

  <div class="cta-stamps">
    <a class="cta-stamp cta-free" href="/download"><span class="ink"></span>Baixar grátis</a>
    <a class="cta-stamp cta-buy" href="#"><span class="ink"></span>Adquirir na Amazon — em breve</a>
  </div>

  <p class="hint">abra os anexos · <span>desclassifique o que puder</span></p>
</DossieFrame>

<style>
  .tese-home { font-family: var(--font-display); font-size: clamp(24px, 4.5vw, 44px);
    line-height: 1.1; margin: 32px 0 8px; text-transform: uppercase; letter-spacing: .01em; color: var(--osso); }
  .slogan-unico { font-family: var(--font-corpo); font-size: clamp(15px, 2.2vw, 19px);
    line-height: 1.6; color: var(--osso); border-left: 3px solid var(--brasa); padding-left: 16px;
    margin: 0 0 10px; max-width: 680px; }
  .slogan-unico span { color: var(--cinza-morto); }
</style>
