---
import DossieFrame from '../layouts/DossieFrame.astro';
import Terminal from '../components/Terminal.astro';
import SubjectCard from '../components/SubjectCard.astro';
export const prerender = false;
const { showTerminal } = Astro.locals;
---
{showTerminal && <Terminal />}
<DossieFrame title="O Outro Manifesto Cypherpunk">
  <SubjectCard />
  <p class="tese">Você deixou de ser cidadão. Virou usuário.</p>
  <nav class="anexos">
    <a href="/livro">› ANEXO A · O DOCUMENTO</a>
    <a href="/autor">› ANEXO B · O INFORMANTE</a>
    <a href="/download">› ANEXO C · LIBERAÇÃO</a>
  </nav>
  <div class="ctas">
    <a class="cta" href="/download">Baixar grátis</a>
    <a class="cta ghost" href="#">Comprar na Amazon</a>
  </div>
</DossieFrame>

<style>
  .tese { font-family: var(--font-display); font-size: clamp(22px, 4vw, 40px); color: var(--osso);
    margin: 28px 0; line-height: 1.15; }
  .anexos { display: flex; flex-direction: column; gap: 8px; font-family: var(--font-mono); }
  .anexos a, .cta { color: var(--brasa-claro); text-decoration: none; }
  .ctas { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
  .cta { border: 1px solid var(--brasa); padding: 10px 18px; font-family: var(--font-display); }
  .cta.ghost { border-color: var(--aco); color: var(--aco-claro); }
</style>
