---
// Overlay de atmosfera (grain feTurbulence + scanlines + vinheta + flicker). Port de 03-dossie.html.
---
<div class="fx fx-grain" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg">
    <filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" stitchTiles="stitch"/></filter>
    <rect width="100%" height="100%" filter="url(#noise)"></rect>
  </svg>
</div>
<div class="fx fx-scan" aria-hidden="true"></div>
<div class="fx fx-flicker" aria-hidden="true"></div>
<div class="fx fx-vignette" aria-hidden="true"></div>
