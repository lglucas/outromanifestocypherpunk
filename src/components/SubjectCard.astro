---
// Ficha do sujeito (SUJEITO) no layout do protótipo. Valores reais preenchidos no cliente.
import HoodedFigure from './dossie/svg/HoodedFigure.astro';
---
<div class="subject-grid">
  <div>
    <div class="field"><span class="k">SUJEITO</span><span class="v big"><span data-egg="nome">SUJEITO Nº 0001</span> <span style="color:var(--brasa2)">"você"</span></span></div>
    <div class="field"><span class="k">LOCALIZAÇÃO ESTIMADA</span><span class="v" data-egg="localizacao">—</span></div>
    <div class="field"><span class="k">OPERADORA / NÓ DE SAÍDA</span><span class="v" data-egg="operadora">—</span></div>
    <div class="field"><span class="k">DISPOSITIVO</span><span class="v" data-egg="maquina">—</span></div>
    <div class="field"><span class="k">ENDEREÇO IP</span><span class="v" data-egg="ip">—</span></div>
    <div class="status-line"><span class="k">PREDIÇÃO COMPORTAMENTAL</span><br /><span class="v">CUMPRIRÁ OS TERMOS SEM LER</span></div>
  </div>
  <div>
    <div class="mug">
      <HoodedFigure />
      <div class="grid-h"></div>
      <span class="corner c1"></span><span class="corner c2"></span>
      <span class="corner c3"></span><span class="corner c4"></span>
      <span class="scanid"></span>
    </div>
    <div class="mug-cap">captura automática · sem consentimento</div>
  </div>
</div>

<div class="scores">
  <div class="score"><div class="lbl">Índice de comportamento</div><div class="val">7/10</div><div class="bars">████████░░</div><div class="note">tendência: recusa precoce</div></div>
  <div class="score danger"><div class="lbl">Nível de risco</div><div class="val">ESCALANDO</div><div class="bars">▲ ▲ ▲</div><div class="note">leitura em progresso</div></div>
  <div class="score"><div class="lbl">Classe de privacidade</div><div class="val">ANORMAL</div><div class="bars">! !</div><div class="note">demanda monitoramento</div></div>
</div>

<script>
  import { fillEasterEggs } from '../features/dossie/fill-easter-eggs';
  fillEasterEggs();
</script>
