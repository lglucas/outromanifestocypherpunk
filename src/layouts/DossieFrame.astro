---
import HudBars from '../components/HudBars.astro';
import ReopenTerminal from '../components/ReopenTerminal.astro';
import '../styles/global.css';
interface Props { title?: string }
const { title = 'O Outro Manifesto Cypherpunk' } = Astro.props;
---
<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="dossie-body">
    <HudBars />
    <main class="dossie-main"><slot /></main>
    <div class="atmos" aria-hidden="true"></div>
    <ReopenTerminal />
  </body>
</html>

<style is:global>
  .dossie-body { background: var(--vazio); color: var(--osso); font-family: var(--font-corpo);
    margin: 0; min-height: 100vh; }
  .dossie-main { max-width: 960px; margin: 0 auto; padding: 56px 20px 56px; position: relative; z-index: 1; }
  .atmos { position: fixed; inset: 0; pointer-events: none; z-index: 30;
    background:
      repeating-linear-gradient(0deg, rgba(0,0,0,.15) 0 1px, transparent 1px 3px),
      radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,.55) 100%); }
</style>
