---
import '../styles/global.css';
import Atmosphere from '../components/dossie/Atmosphere.astro';
import FolderTabs from '../components/dossie/FolderTabs.astro';
import Camera from '../components/dossie/svg/Camera.astro';
import Crosshair from '../components/dossie/svg/Crosshair.astro';
import AnarchistA from '../components/dossie/svg/AnarchistA.astro';
import ReopenTerminal from '../components/ReopenTerminal.astro';
interface Props { title?: string; current?: string }
const { title = 'O Outro Manifesto Cypherpunk', current = '/' } = Astro.props;
---
<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="dossie-body paper-grain">
    <Atmosphere />
    <Crosshair class="motif m-cross" />
    <AnarchistA class="motif m-anar" />

    <div class="classbar">
      <div class="classbar-in">
        <span class="blink-dot" aria-hidden="true"></span>
        <span class="cls">CLASSIFICADO · NÍVEL VERMELHO</span>
        <span class="prot">PROTOCOLO AÇO-2.6</span>
        <span class="spacer"></span>
        <span class="prot" data-clock>--:--:--</span>
      </div>
    </div>

    <div class="wrap">
      <header class="dochead">
        <div class="docrow">
          <div class="agency">
            DEPARTAMENTO DE INFERÊNCIA TOTAL
            <small>DIVISÃO DE ANÁLISE COMPORTAMENTAL</small>
          </div>
          <Camera />
        </div>
        <FolderTabs current={current} />
      </header>

      <main><slot /></main>

      <footer class="protocol">
        <div class="proto-no">PROTOCOLO 0001 · CC BY-SA 4.0</div>
        <div class="ghost">não há para onde correr</div>
        <div class="authorline">
          Lucas Lopes Galvão · <a href="/autor">o informante</a> ·
          <a href="https://outromanifesto.space">outromanifesto.space</a>
        </div>
      </footer>
    </div>

    <ReopenTerminal />

    <script>
      const clock = document.querySelector('[data-clock]');
      if (clock) {
        const tick = () => { clock.textContent = new Date().toLocaleTimeString('pt-BR'); };
        tick();
        setInterval(tick, 1000);
      }
    </script>
  </body>
</html>

<style is:global>
  .dossie-body { margin: 0; min-height: 100vh; }
</style>
