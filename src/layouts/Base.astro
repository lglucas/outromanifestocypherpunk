---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { t, type Lang } from '../i18n/ui';
const lang = (Astro.currentLocale ?? 'pt') as Lang;
interface Props { title?: string }
const { title } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title ? `${title} · ${t(lang, 'site.title')}` : t(lang, 'site.title')}</title>
  </head>
  <body class="min-h-screen bg-neutral-950 text-neutral-100 font-sans antialiased">
    <header class="flex items-center justify-between px-6 py-4 border-b border-neutral-800">
      <a href="/" class="font-mono text-sm tracking-tight">{t(lang, 'site.title')}</a>
      <LanguageSwitcher />
    </header>
    <main class="mx-auto max-w-3xl px-6 py-16"><slot /></main>
    <footer class="px-6 py-8 text-xs text-neutral-500 border-t border-neutral-800">
      CC BY-SA 4.0 · Lucas Lopes Galvão
    </footer>
  </body>
</html>