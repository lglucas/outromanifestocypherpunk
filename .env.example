# Runtime do site (preenchido no VPS em /opt/livro/.env, chmod 600)
PORT=3000
PUBLIC_SITE_URL=https://outromanifesto.space
# Listmonk - endereco interno na rede Docker compartilhada (lead via terminal, D1)
LISTMONK_API_URL=http://listmonk:9000
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
LISTMONK_LIST_ID=

# Geo-IP local (bancos DB-IP Lite baixados em data/*.mmdb no build; sem API externa)
# Sem variaveis de credencial - os arquivos .mmdb sao publicos (licenca CC).